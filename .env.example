NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
NEXT_PUBLIC_BASE_PATH=
APP_PASSWORD=
DATABASE_PATH=data/usstock/usstock_cockpit.db
LOCAL_STATE_PATH=data/usstock/local_state.json
MARKET_CACHE_DIR=data/usstock/market_cache

# Optional market/fundamental data sources.
FMP_API_KEY=
TUSHARE_TOKEN=

# Backend execution mode: paper | usmart-paper | usmart-live | ibkr-paper | ibkr-live | za-manual
BROKER_MODE=paper

# uSMART / 香港盈立 Open API. Apply in uSMART first; do not commit real values.
USMART_BASE_URL=http://open-jy-uat.yxzq.com
USMART_CHANNEL=
USMART_AUTHORIZATION=
USMART_PRIVATE_KEY_PATH=
USMART_ORDER_PATH=/stock-trade/entrust
USMART_ALLOW_NETWORK_SUBMIT=false

# IBKR Gateway/TWS connection. 7497 is commonly paper, 7496 is commonly live.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=17

# Live orders are blocked unless this is exactly true.
ENABLE_LIVE_TRADING=false
