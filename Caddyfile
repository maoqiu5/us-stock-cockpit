{
	# Legacy reference only. The production gateway now belongs in:
	# /root/apps/brianhub-gateway
	# /Users/brian/Documents/brianhub-gateway
	# Do not deploy this file from the usstock project after gateway migration.

	email {$TLS_EMAIL}
}

{$APP_DOMAIN} {
	encode zstd gzip

	redir / /usstock

	route /usstock/api/* {
		uri strip_prefix /usstock/api
		reverse_proxy usstock_backend:8000
	}

	route /usstock* {
		reverse_proxy usstock_frontend:3000
	}

	route /maildesk/api/* {
		uri strip_prefix /maildesk/api
		reverse_proxy maildesk_backend:8000
	}

	redir /maildesk/wps-browser /maildesk/wps-browser/vnc.html?autoconnect=1&resize=scale 302

	handle_path /maildesk/wps-browser/* {
		basic_auth {
			brian {$MAILDESK_WPS_BASIC_AUTH_HASH}
		}
		reverse_proxy 172.19.0.1:6080
	}

	route /maildesk* {
		reverse_proxy maildesk_frontend:3000
	}

	route /cnstock/api/* {
		uri strip_prefix /cnstock/api
		reverse_proxy cnstock_backend:8000
	}

	route /cnstock* {
		reverse_proxy cnstock_frontend:3000
	}
}
